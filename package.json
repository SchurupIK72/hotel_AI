{
  "name": "hotel-ai-manager",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test:ph1-01": "node --experimental-strip-types ./tests/ph1-01/run-checks.ts",
    "test:ph1-02": "node --experimental-strip-types ./tests/ph1-02/run-checks.ts",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:status:env": "supabase status -o env",
    "demo:bootstrap": "node ./scripts/bootstrap-local-demo.mjs",
    "verify:ph1-01": "node ./scripts/verify-ph1-01-smoke.mjs",
    "dev:setup": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-setup.ps1",
    "dev:stop": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-stop.ps1"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.4",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "supabase": "^2.53.0",
    "typescript": "^5.8.2"
  }
}
